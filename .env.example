# iFu Labs — Comply API

# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://ifu_labs:password@localhost:5432/ifu_labs_comply_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.ifu-labs.io
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret

# Paystack (https://dashboard.paystack.com/#/settings/developers)
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=whsec_...
PAYSTACK_COMPLY_STARTER_PLAN=PLN_...
PAYSTACK_COMPLY_GROWTH_PLAN=PLN_...
PAYSTACK_FINOPS_PLAN=PLN_...

# AWS (iFu Labs own account — for assuming customer roles)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
IFU_LABS_AWS_ACCOUNT_ID=123456789012

# JWT Secret (REQUIRED — server will not start without this)
JWT_SECRET=generate-with-openssl-rand-hex-64

# Encryption (REQUIRED — for storing customer credentials)
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Amazon Bedrock (AI gap explanations)
BEDROCK_REGION=us-east-1

# GitHub App (for GitHub connector)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Resend Email Service (https://resend.com)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=onboarding@resend.dev
PORTAL_URL=https://portal.ifu-labs.io

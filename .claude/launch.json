{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server (Fastify)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nodemon", "src/index.js"],
      "port": 3000
    },
    {
      "name": "Comply Frontend (Next.js)",
      "runtimeExecutable": "npm",

      "port": 3002,
      "cwd": "finops"
    },
    {
      "name": "Portal (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3003,
      "cwd": "portal"
    },
    {
      "name": "Website (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3004,
      "cwd": "website"
    }
  ]
}
